<?xml version="1.0" encoding="UTF-8"?><ui version="4.0"><class>StudentManagementPage</class><widget class="QWidget" name="StudentManagementPage"><layout class="QVBoxLayout">
<item><widget class="QLabel" name="heading"><property name="text"><string>Student Management</string></property><property name="styleSheet"><string>font-size:22pt;font-weight:700;</string></property></widget></item><item><layout class="QHBoxLayout"><item><widget class="QLineEdit" name="searchEdit"><property name="placeholderText"><string>Search by registration number or name…</string></property></widget></item><item><widget class="QPushButton" name="addButton"><property name="text"><string>+ Add Student</string></property></widget></item></layout></item>
<item><layout class="QHBoxLayout"><item><widget class="QTableView" name="studentTable"><property name="sortingEnabled"><bool>true</bool></property><property name="selectionBehavior"><enum>QAbstractItemView::SelectRows</enum></property><property name="selectionMode"><enum>QAbstractItemView::SingleSelection</enum></property></widget></item><item><widget class="QFrame" name="detailFrame"><property name="minimumSize"><size><width>270</width><height>0</height></size></property><layout class="QVBoxLayout"><item><widget class="QLabel" name="photoLabel"><property name="minimumSize"><size><width>220</width><height>220</height></size></property><property name="text"><string>No photo</string></property><property name="alignment"><set>Qt::AlignCenter</set></property></widget></item><item><widget class="QLineEdit" name="regEdit"><property name="placeholderText"><string>Registration number</string></property></widget></item><item><widget class="QLineEdit" name="nameEdit"><property name="placeholderText"><string>Student name</string></property></widget></item><item><widget class="QPushButton" name="saveButton"><property name="text"><string>Save Changes</string></property></widget></item><item><widget class="QPushButton" name="deleteButton"><property name="text"><string>Delete Student</string></property></widget></item><item><spacer name="detailSpacer"><property name="orientation"><enum>Qt::Vertical</enum></property></spacer></item></layout></widget></item></layout></item></layout></widget><resources/><connections/></ui>
