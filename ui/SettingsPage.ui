<?xml version="1.0" encoding="UTF-8"?><ui version="4.0"><class>SettingsPage</class><widget class="QWidget" name="SettingsPage"><layout class="QVBoxLayout"><item><widget class="QLabel" name="heading"><property name="text"><string>Application Settings</string></property><property name="styleSheet"><string>font-size:22pt;font-weight:700;</string></property></widget></item><item><widget class="QFrame" name="settingsCard"><layout class="QFormLayout"><item row="0" column="0"><widget class="QLabel" name="cameraTitle"><property name="text"><string>Default camera</string></property></widget></item><item row="0" column="1"><widget class="QComboBox" name="cameraCombo"/></item><item row="1" column="0"><widget class="QLabel" name="themeTitle"><property name="text"><string>Theme</string></property></widget></item><item row="1" column="1"><widget class="QComboBox" name="themeCombo"><item><property name="text"><string>Dark</string></property></item><item><property name="text"><string>Light</string></property></item></widget></item><item row="2" column="0"><widget class="QLabel" name="thresholdTitle"><property name="text"><string>Recognition threshold</string></property></widget></item><item row="2" column="1"><widget class="QDoubleSpinBox" name="thresholdSpin"><property name="minimum"><double>20.0</double></property><property name="maximum"><double>90.0</double></property><property name="value"><double>45.0</double></property></widget></item><item row="3" column="0"><widget class="QLabel" name="backupTitle"><property name="text"><string>Backup folder</string></property></widget></item><item row="3" column="1"><layout class="QHBoxLayout"><item><widget class="QLineEdit" name="backupEdit"/></item><item><widget class="QPushButton" name="browseButton"><property name="text"><string>Browse</string></property></widget></item></layout></item><item row="4" column="1"><widget class="QCheckBox" name="autoBackupCheck"><property name="text"><string>Automatically back up CSV data on exit</string>